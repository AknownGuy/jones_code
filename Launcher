local requestFn =
    (syn and syn.request)
    or (http and http.request)
    or http_request
    or request

local function githubApiUrl(path)
    return string.format(
        "https://api.github.com/repos/%s/%s/%s",
        HttpService:UrlEncode(GITHUB_USER),
        HttpService:UrlEncode(GITHUB_REPO),
        path
    )
end

local function rawFileUrl(path)
    local safePath = path:gsub("^/+", "")
    return string.format(
        "https://raw.githubusercontent.com/%s/%s/%s/%s",
        GITHUB_USER,
        GITHUB_REPO,
        GITHUB_BRANCH,
        safePath
    )
end

local function httpGet(url, useGithubHeaders)
    if type(requestFn) == "function" then
        local response = requestFn({
            Url = url,
            Method = "GET",
            Headers = useGithubHeaders and {
                ["Accept"] = "application/vnd.github+json",
                ["User-Agent"] = "RobloxRepoLauncher",
                ["X-GitHub-Api-Version"] = "2022-11-28",
            } or {},
        })

        if not response then
            error("No response from request function")
        end

        local statusCode = tonumber(response.StatusCode or response.Status) or 0
        if statusCode < 200 or statusCode >= 300 then
            error(("HTTP %d: %s"):format(statusCode, tostring(response.Body)))
        end

        return response.Body or ""
    end

    if game and game.HttpGet then
        local ok, body = pcall(function()
            return game:HttpGet(url)
        end)

        if ok then
            return body
        end
    end

    error("No supported HTTP function found")
end

local function fetchLuaFiles()
    local url = githubApiUrl("git/trees/" .. HttpService:UrlEncode(GITHUB_BRANCH) .. "?recursive=1")
    local body = httpGet(url, true)
    local decoded = HttpService:JSONDecode(body)
    local tree = decoded and decoded.tree

    if type(tree) ~= "table" then
        error("GitHub tree response was missing file data")
    end

    local files = {}

    for _, item in ipairs(tree) do
        if item.type == "blob" and type(item.path) == "string" and item.path:lower():match("%.lua$") then
            table.insert(files, {
                name = item.path:match("([^/]+)$") or item.path,
                path = item.path,
                url = rawFileUrl(item.path),
            })
        end
    end

    table.sort(files, function(a, b)
        return a.path:lower() < b.path:lower()
    end)

    return files
end

local function makeCorner(instance, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius)
    corner.Parent = instance
