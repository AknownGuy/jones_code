local loading = false
local currentButtons = {}

local function clearButtons()
    for _, instance in ipairs(currentButtons) do
        if instance and instance.Parent then
            instance:Destroy()
        end
    end
    table.clear(currentButtons)
end

local function setStatus(text, color)
    statusLabel.Text = text
    statusLabel.TextColor3 = color or C.blue
end

local function launchScript(fileInfo)
    if loading then
        return
    end

    loading = true
    setStatus("Downloading " .. fileInfo.name .. "...", C.gold)

    local ok, sourceOrError = pcall(function()
        return httpGet(fileInfo.url, false)
    end)

    if not ok then
        loading = false
        setStatus("Download failed: " .. tostring(sourceOrError), C.red)
        return
    end

    if type(loadstring) ~= "function" then
        loading = false
        setStatus("This executor does not support loadstring", C.red)
        return
    end

    local chunk, compileError = loadstring(sourceOrError, fileInfo.name)
    if not chunk then
        loading = false
        setStatus("Compile failed: " .. tostring(compileError), C.red)
        return
    end

    local env = (getgenv and getgenv()) or _G
    env.SelectedGithubScript = fileInfo.path
    env.SelectedGithubScriptUrl = fileInfo.url

    gui:Destroy()

    local runOk, runError = pcall(chunk)
    if not runOk then
        warn("[Launcher] Script runtime error: " .. tostring(runError))
    end
end

