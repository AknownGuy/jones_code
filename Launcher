local function loadRepoScripts()
    if loading then
        return
    end

    loading = true
    clearButtons()
    setStatus("Scanning GitHub repo for .lua files...", C.blue)

    local ok, filesOrError = pcall(fetchLuaFiles)
    if not ok then
        loading = false
        setStatus("Failed to scan repo: " .. tostring(filesOrError), C.red)
        return
    end

    local files = filesOrError

    if #files == 0 then
        loading = false
        setStatus("No .lua files found in repo", C.red)
        return
    end

    for _, fileInfo in ipairs(files) do
        addScriptButton(fileInfo)
    end

    loading = false
    setStatus("Found " .. #files .. " Lua scripts", C.green)
end

