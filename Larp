local function launchEntry(entry, options)
    if launcherClosed then
        return
    end

    options = options or {}

    setStatus("Downloading " .. entry.name .. "...", COLORS.warning)

    if entry.commit then
        setSelectedCommit(entry.name, entry.commit)
    else
        selectedCommitLabel.Text = "Selected script commit: Unable to load commit info"
    end

    local source = entry.source
    if type(source) ~= "string" or source == "" then
        local okSource, result = pcall(function()
            return httpGet(entry.url, false)
        end)

        if not okSource then
            setStatus("Failed to download " .. entry.name, COLORS.danger)
            return
        end

        source = result
        entry.source = source
    end

    local chunk, loadError = loadstring(source)
    if not chunk then
        setStatus("Script compile failed for " .. entry.name, COLORS.danger)
        warn("[LARP Hub Launcher] " .. tostring(loadError))
        return
    end

    settings.lastScriptPath = entry.path
    saveSettings()

    setStatus("Launching " .. entry.name .. "...", COLORS.success)
    task.wait(0.1)

    if options.minimizeAfterLaunch then
        setMinimized(true)
    elseif options.closeAfterLaunch ~= false then
        closeLauncher()
    end

    task.spawn(function()
        local okRun, runtimeError = pcall(chunk)
        if not okRun then
            warn("[LARP Hub Launcher] " .. tostring(runtimeError))
        end
    end)
end

