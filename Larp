    local tabEntries = categorizedEntries[currentTab] or {}
    if #tabEntries == 0 then
        createInfoRow(
            currentTab == "games"
                and "No scripts are tagged for the Games tab. Use '-- # games' on the first line."
                or "No scripts are tagged for the Tools tab. Use '-- # tools' on the first line.",
            COLORS.subtext
        )
        return
    end

    for _, entry in ipairs(tabEntries) do
        createEntryButton(entry)
    end
end

