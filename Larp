end

local function makeApiUrl(path, query)
    local url = string.format("https://api.github.com/repos/%s/%s/%s", GITHUB_USER, GITHUB_REPO, path)
    if query then
        url = url .. "?" .. query
    end
    return url
end

local function makeRawUrl(path)
    local safePath = path:gsub("^/+", "")
    return string.format(
        "https://raw.githubusercontent.com/%s/%s/%s/%s",
        GITHUB_USER,
        GITHUB_REPO,
        GITHUB_BRANCH,
        safePath
    )
end

local function httpGet(url, useGithubHeaders)
    if type(requestFn) == "function" then
        local response = requestFn({
            Url = url,
            Method = "GET",
            Headers = useGithubHeaders and {
                ["Accept"] = "application/vnd.github+json",
                ["User-Agent"] = "LARP-Hub-Launcher",
                ["X-GitHub-Api-Version"] = "2022-11-28",
            } or {},
        })

        if not response then
            error("No response received from the HTTP request function.")
        end

        local statusCode = tonumber(response.StatusCode or response.Status) or 0
        if statusCode < 200 or statusCode >= 300 then
            error(("GitHub request failed (%d): %s"):format(statusCode, tostring(response.Body or response.StatusMessage or "Unknown error")))
        end

        return response.Body or ""
    end

    if not useGithubHeaders and game and game.HttpGet then
        local ok, body = pcall(function()
            return game:HttpGet(url)
        end)

        if ok then
            return body
        end
    end

    error("This launcher needs an executor HTTP request function for GitHub API access.")
end

local function decodeJson(body)
    local ok, data = pcall(function()
        return HttpService:JSONDecode(body)
    end)

    if not ok then
        error("GitHub returned invalid JSON.")
    end

    return data
end

local function hasDeprecatedSegment(path)
    for segment in string.gmatch(path, "[^/]+") do
        if segment:lower() == "deprecated" then
            return true
        end
    end

    return false
end

local function shortenMessage(message, maxLength)
    local safeMessage = tostring(message or "No message"):gsub("%s+", " ")
    if #safeMessage <= maxLength then
        return safeMessage
    end

    return safeMessage:sub(1, maxLength - 3) .. "..."
end

local function supportsFileSettings()
    return type(isfolder) == "function"
        and type(makefolder) == "function"
        and type(isfile) == "function"
        and type(writefile) == "function"
        and type(readfile) == "function"
end

local function loadSettings()
    local defaults = {
        autoExec = false,
        lastScriptPath = nil,
    }

    if not supportsFileSettings() then
        return defaults
    end

    pcall(function()
        if not isfolder(SETTINGS_FOLDER) then
            makefolder(SETTINGS_FOLDER)
        end
    end)

    if not isfile(SETTINGS_FILE) then
        return defaults
    end

    local ok, raw = pcall(readfile, SETTINGS_FILE)
    if not ok or type(raw) ~= "string" or raw == "" then
        return defaults
    end

    local okDecode, decoded = pcall(function()
        return HttpService:JSONDecode(raw)
    end)

    if not okDecode or type(decoded) ~= "table" then
        return defaults
    end

    return {
        autoExec = decoded.autoExec == true,
        lastScriptPath = type(decoded.lastScriptPath) == "string" and decoded.lastScriptPath or nil,
    }
end

local settings = loadSettings()

local function saveSettings()
    if not supportsFileSettings() then
        return false
    end

    local ok = pcall(function()
        if not isfolder(SETTINGS_FOLDER) then
            makefolder(SETTINGS_FOLDER)
        end

        writefile(SETTINGS_FILE, HttpService:JSONEncode({
            autoExec = settings.autoExec == true,
            lastScriptPath = settings.lastScriptPath,
        }))
    end)

    return ok
end

local commitCache = {}

local function getLatestCommit(path)
    if commitCache[path] then
        return commitCache[path]
    end

    local query = string.format(
        "sha=%s&path=%s&per_page=1",
        HttpService:UrlEncode(GITHUB_BRANCH),
        HttpService:UrlEncode(path)
    )
    local body = httpGet(makeApiUrl("commits", query), true)
    local data = decodeJson(body)
    local latest = data and data[1]

    if type(latest) ~= "table" then
        error("No commit data was returned for " .. path)
    end

    local commit = {
        sha = tostring(latest.sha or "unknown"),
        shortSha = tostring(latest.sha or "unknown"):sub(1, 7),
        message = latest.commit and latest.commit.message or "No message",
        date = latest.commit and latest.commit.committer and latest.commit.committer.date or "Unknown date",
    }

    commitCache[path] = commit
    return commit
end

local function getRepoTree()
    local body = httpGet(makeApiUrl("git/trees/" .. GITHUB_BRANCH, "recursive=1"), true)
    local data = decodeJson(body)
    if type(data) ~= "table" or type(data.tree) ~= "table" then
        error("GitHub tree response did not include file data.")
    end

    return data.tree
end

local function buildLaunchEntries(tree)
    local rootFolders = {}
    local files = {}

    for _, item in ipairs(tree) do
        local path = item.path
        if type(path) == "string" and not hasDeprecatedSegment(path) then
            local firstFolder = path:match("^([^/]+)/")
            if firstFolder then
                rootFolders[firstFolder] = true
            end

            if item.type == "blob" then
                files[path] = true
            end
        end
    end

    local entries = {}

    for folderName in pairs(rootFolders) do
        local scriptPath = folderName .. "/" .. folderName .. ".lua"
        if files[scriptPath] then
            table.insert(entries, {
                name = folderName,
                path = scriptPath,
                url = makeRawUrl(scriptPath),
                category = "games",
                source = nil,
                commit = nil,
            })
        end
    end

    table.sort(entries, function(a, b)
        return a.name:lower() < b.name:lower()
    end)

    return entries
end

local function makeCorner(instance, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius)
    corner.Parent = instance
    return corner
end

local function makeStroke(instance, color, transparency, thickness)
    local stroke = Instance.new("UIStroke")
    stroke.Color = color
    stroke.Transparency = transparency or 0
    stroke.Thickness = thickness or 1
    stroke.Parent = instance
    return stroke
end

local function parseCategoryFromFirstLine(source)
    local firstLine = tostring(source or ""):match("([^\r\n]*)") or ""
    local normalized = firstLine:lower()
    normalized = normalized:gsub("^%s*%-%-+%s*", "")
    normalized = normalized:gsub("^%s*#%s*", "")
    normalized = normalized:gsub("^%s*category%s*:%s*", "")
    normalized = normalized:match("^%s*(.-)%s*$") or ""
    normalized = normalized:gsub("[^%a%s]", " ")
    normalized = normalized:gsub("%s+", " ")

    if normalized == "game" or normalized == "games" then
        return "games"
    end

    if normalized == "tool" or normalized == "tools" then
        return "tools"
    end

    return nil
end

