local function launchEntry(entry)
    setStatus("Downloading " .. entry.name .. "...", COLORS.warning)
    selectedCommitLabel.Text = "Selected script commit: Loading..."
    local okCommit, commit = pcall(function()
        return entry.commit or getLatestCommit(entry.path)
    end)
    if okCommit and commit then
        entry.commit = commit
        setSelectedCommit(entry.name, commit)
    else
        selectedCommitLabel.Text = "Selected script commit: Unable to load commit info"
    end
    local okSource, source = pcall(function()
        return httpGet(entry.url, false)
    end)
    if not okSource then
        setStatus("Failed to download " .. entry.name, COLORS.danger)
        return
    end
    local chunk, loadError = loadstring(source)
    if not chunk then
        setStatus("Script compile failed for " .. entry.name, COLORS.danger)
        warn("[LARP Hub Launcher] " .. tostring(loadError))
        return
    end
    setStatus("Launching " .. entry.name .. "...", COLORS.success)
    task.wait(0.1)
    destroyLauncher()
    task.spawn(function()
        local ok, runtimeError = pcall(chunk)
        if not ok then
            warn("[LARP Hub Launcher] " .. tostring(runtimeError))
        end
    end)
end
