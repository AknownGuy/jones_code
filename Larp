task.spawn(function()
    clearList()

    if type(requestFn) ~= "function" then
        setStatus("Executor request function required for GitHub API access.", COLORS.danger)
        launcherCommitLabel.Text = "Launcher commit: Unavailable"
        selectedCommitLabel.Text = "Selected script commit: Unavailable"
        createInfoRow("Your executor needs request support so the launcher can scan scripts and read commit data.", COLORS.subtext)
        return
    end

    local okLauncherCommit, launcherCommit = pcall(function()
        return getLatestCommit(LAUNCHER_PATH)
    end)

    if okLauncherCommit then
        setLauncherCommit(launcherCommit)
    else
        launcherCommitLabel.Text = "Launcher commit: Unable to load"
    end

    local okTree, treeOrError = pcall(function()
        return getRepoTree()
    end)

    if not okTree then
        setStatus("Failed to read LARP_Hub repository tree.", COLORS.danger)
        createInfoRow(tostring(treeOrError), COLORS.subtext)
        return
    end

    local entries = buildLaunchEntries(treeOrError)
    if #entries == 0 then
        setStatus("No launchable scripts found.", COLORS.warning)
        createInfoRow("No top-level folders contained a matching FolderName/FolderName.lua file after Deprecated paths were ignored.", COLORS.subtext)
        return
    end

    for index, entry in ipairs(entries) do
        setStatus(("Inspecting %s (%d/%d)..."):format(entry.name, index, #entries), COLORS.accent)

        local okSource, sourceOrError = pcall(function()
            return httpGet(entry.url, false)
        end)

        if okSource and type(sourceOrError) == "string" then
            entry.source = sourceOrError
            entry.category = parseCategoryFromFirstLine(sourceOrError) or "games"
        else
            entry.category = "games"
        end

        local okCommit, commitOrError = pcall(function()
            return getLatestCommit(entry.path)
        end)

        if okCommit then
            entry.commit = commitOrError
        else
            warn("[LARP Hub Launcher] Commit lookup failed for " .. entry.path .. ": " .. tostring(commitOrError))
        end
    end

    categorizedEntries = {
        games = {},
        tools = {},
    }

    for _, entry in ipairs(entries) do
        table.insert(categorizedEntries[entry.category] or categorizedEntries.games, entry)
    end

    if #categorizedEntries.games == 0 and #categorizedEntries.tools > 0 then
        currentTab = "tools"
    else
        currentTab = "games"
    end

    if #categorizedEntries.games == 0 and #categorizedEntries.tools == 0 then
        createInfoRow("No scripts matched the category rules. Add '-- # games' or '-- # tools' as the first line of each script.", COLORS.subtext)
        setStatus("No categorized scripts found.", COLORS.warning)
        return
    end

    renderCurrentTab()
    setStatus(("Loaded %d launchable script%s."):format(#entries, #entries == 1 and "" or "s"), COLORS.success)

    if settings.autoExec and type(settings.lastScriptPath) == "string" then
        for _, entry in ipairs(entries) do
            if entry.path == settings.lastScriptPath then
                setStatus("Autoexec is enabled. Launching " .. entry.name .. " and minimizing launcher...", COLORS.warning)
                task.delay(0.35, function()
                    if not launcherClosed then
                        launchEntry(entry, {
                            closeAfterLaunch = false,
                            minimizeAfterLaunch = true,
                        })
                    end
                end)
                break
            end
        end
    end
end)
