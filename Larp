local function closeLauncher()
    if launcherClosed then
        return
    end

    launcherClosed = true

    for _, connection in ipairs(connections) do
        pcall(function()
            connection:Disconnect()
        end)
    end

    table.clear(connections)

    if gui and gui.Parent then
        gui:Destroy()
    end
end

