task.spawn(function()
    clearList()
    if type(requestFn) ~= "function" then
        setStatus("Executor request function required for GitHub API access.", COLORS.danger)
        launcherCommitLabel.Text = "Launcher commit: Unavailable"
        selectedCommitLabel.Text = "Selected script commit: Unavailable"
        createEmptyState("Your executor needs request support so the launcher can scan the repo tree and read commit data.")
        return
    end
    local okLauncherCommit, launcherCommit = pcall(function()
        return getLatestCommit(LAUNCHER_PATH)
    end)
    if okLauncherCommit then
        setLauncherCommit(launcherCommit)
    else
        launcherCommitLabel.Text = "Launcher commit: Unable to load"
    end
    local okTree, treeOrError = pcall(function()
        return getRepoTree()
    end)
    if not okTree then
        setStatus("Failed to read LARP_Hub repository tree.", COLORS.danger)
        createEmptyState(tostring(treeOrError))
        return
    end
    local entries = buildLaunchEntries(treeOrError)
    if #entries == 0 then
        setStatus("No launchable scripts found.", COLORS.warning)
        createEmptyState("No top-level folders contained a matching FolderName/FolderName.lua file after Deprecated paths were ignored.")
        return
    end
    for _, entry in ipairs(entries) do
        createEntryButton(entry)
    end
    setStatus(("Loaded %d launchable script%s."):format(#entries, #entries == 1 and "" or "s"), COLORS.success)
end)